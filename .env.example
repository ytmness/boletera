# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://<YOUR_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<YOUR_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SERVICE_ROLE_KEY>
SUPABASE_PUBLISHABLE_KEY=<YOUR_PUBLISHABLE_KEY>

# Database (Prisma)
DATABASE_URL=postgresql://postgres:<YOUR_PASSWORD>@db.<YOUR_REF>.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:<YOUR_PASSWORD>@db.<YOUR_REF>.supabase.co:5432/postgres?sslmode=require

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Grupo Regia - Boletera"

# QR Code Configuration
QR_SECRET_KEY=change-this-in-production

# Auth
JWT_SECRET=tu-secret-key-super-seguro-cambiar-en-produccion-12345678
