# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=tu-proyecto-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Database (Prisma utiliza la conexión directa de Supabase)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Grupo Regia - Boletera"

# QR Code Configuration
QR_SECRET_KEY=change-this-in-production

# Email (opcional para ahora, necesario cuando implementes notificaciones)
# RESEND_API_KEY=re_xxxxx

# Payment Gateway (para FASE futura)
# STRIPE_SECRET_KEY=sk_test_xxxxx
